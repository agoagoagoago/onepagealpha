# Fathom Analytics configuration.
# Copy this file to `.env.local` and fill in your real Fathom Site ID.
#
# Find your Site ID in the Fathom dashboard: Settings > Sites.
NEXT_PUBLIC_FATHOM_SITE_ID=YOUR_FATHOM_SITE_ID

# Optional: only change this if you use a custom Fathom script domain
# (Fathom "custom domain" feature for bypassing ad blockers).
# Leave as the default if you are unsure.
NEXT_PUBLIC_FATHOM_SCRIPT_URL=https://cdn.usefathom.com/script.js
