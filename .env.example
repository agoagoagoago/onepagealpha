# Fathom Analytics configuration.
# Copy this file to `.env.local` and fill in your real Fathom Site ID.
#
# Find your Site ID in the Fathom dashboard: Settings > Sites.
NEXT_PUBLIC_FATHOM_SITE_ID=YOUR_FATHOM_SITE_ID

# Optional: only change this if you use a custom Fathom script domain
# (Fathom "custom domain" feature for bypassing ad blockers).
# Leave as the default if you are unsure.
NEXT_PUBLIC_FATHOM_SCRIPT_URL=https://cdn.usefathom.com/script.js

# Formspree endpoint — ONLY for the "Request a Company" form (/request).
# (Gated infographic downloads use Resend, configured below — not Formspree.)
# Create a form at https://formspree.io and paste its endpoint here.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# --- Resend (email-gated infographic downloads) ----------------------------
# Powers the /api/download-request route. RESEND_API_KEY is SERVER-ONLY —
# it must NOT be prefixed with NEXT_PUBLIC_ and is never exposed to the client.
RESEND_API_KEY=re_xxxxxxxxx

# Sender address. In production use a VERIFIED domain, e.g.
# "OnePage Alpha <hello@onepagealpha.com>". If unset, the route falls back to
# "OnePage Alpha <onboarding@resend.dev>" (fine for testing only).
RESEND_FROM_EMAIL=OnePage Alpha <hello@onepagealpha.com>

# Optional: internal notification address. If unset, no owner email is sent.
RESEND_OWNER_EMAIL=your-email@example.com

# Absolute site URL. The API route builds the absolute download link from this.
# Falls back to the request origin if unset.
NEXT_PUBLIC_SITE_URL=https://onepagealpha.com
