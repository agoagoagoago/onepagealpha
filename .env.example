# Fathom Analytics configuration.
# Copy this file to `.env.local` and fill in your real Fathom Site ID.
#
# Find your Site ID in the Fathom dashboard: Settings > Sites.
NEXT_PUBLIC_FATHOM_SITE_ID=YOUR_FATHOM_SITE_ID

# Optional: only change this if you use a custom Fathom script domain
# (Fathom "custom domain" feature for bypassing ad blockers).
# Leave as the default if you are unsure.
NEXT_PUBLIC_FATHOM_SCRIPT_URL=https://cdn.usefathom.com/script.js

# Formspree endpoint for the "Request a Company" form (/request).
# Create a form at https://formspree.io and paste its endpoint here.
# If this is missing, the form shows a helpful notice instead of crashing.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# SEPARATE Formspree endpoint for the email-gated infographic downloads.
# Use a DIFFERENT form than the request form above so you can enable an
# Autoresponse on it. In that form, ensure the submitted field is named `email`,
# then turn on Formspree Autoresponse (see README "Download email capture setup").
# If this is missing, the download gate shows a helpful notice instead of crashing.
NEXT_PUBLIC_FORMSPREE_DOWNLOAD_ENDPOINT=https://formspree.io/f/YOUR_DOWNLOAD_FORM_ID

# Absolute site URL. Used to build an absolute `download_url` so the Formspree
# autoresponse can link to the file. Falls back to a relative path if unset.
NEXT_PUBLIC_SITE_URL=https://onepagealpha.com
